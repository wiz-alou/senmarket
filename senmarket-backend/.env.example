
# ============================================
# .env.example
# ============================================
# Server Configuration
PORT=8080
ENV=development
API_URL=http://localhost:8080

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USER=senmarket
DB_PASSWORD=senmarket123
DB_NAME=senmarket
DB_SSL_MODE=disable

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRY=24h

# MinIO/S3 Configuration
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=senmarket
MINIO_SECRET_KEY=senmarket123
MINIO_BUCKET=senmarket-images
MINIO_SSL=false

# Orange Money API (Sandbox)
ORANGE_MONEY_API_URL=https://api.orange.com/orange-money-webpay/dev
ORANGE_MONEY_MERCHANT_KEY=your-orange-money-key
ORANGE_MONEY_MERCHANT_SECRET=your-orange-money-secret

# SMS Configuration (Senegal)
SMS_PROVIDER=senegal_sms
SMS_API_URL=https://api.senegal-sms.com
SMS_API_KEY=your-sms-api-key
SMS_SENDER=SenMarket

# Email Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=noreply@senmarket.sn

# Security
BCRYPT_COST=12
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=1h

# File Upload
MAX_FILE_SIZE=5242880
ALLOWED_EXTENSIONS=jpg,jpeg,png,webp
IMAGE_QUALITY=85
